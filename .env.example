# Copy to .env and fill in your values.
# All variables are optional unless marked REQUIRED.

# ─── OpenAI / Codex server (acp-server-codex.js) ────────────────────────────

# REQUIRED for codex server — passed to codex-acp child process, never logged
OPENAI_API_KEY=sk-...

# Bind address — defaults to 127.0.0.1 (localhost only, recommended)
# Set to 0.0.0.0 only if you also set ACP_API_KEY (or ALLOW_INSECURE_REMOTE=1)
# HOST=127.0.0.1

# Bearer token(s) for OpenAI server auth. Comma-separate for multiple.
# Required when HOST=0.0.0.0. Leave unset for localhost-only dev.
# ACP_API_KEY=sk-local-dev-key

# Path to codex-acp binary (ships with @zed-industries/codex-acp)
# Linux/Mac:
# CODEX_CMD=./node_modules/.bin/codex-acp
# Windows (bash shebang in .bin/ won't work — use the native exe directly):
# CODEX_CMD=node_modules/@zed-industries/codex-acp-win32-x64/bin/codex-acp.exe

# Default model — "auto" lets codex pick
# CODEX_MODEL_DEFAULT=auto

# Models to list at GET /v1/models (CSV)
# CODEX_AVAILABLE_MODELS=auto,o4-mini,gpt-4o,o3,o3-mini

# Override unsafe remote binding guard — only set if you really mean it
# ALLOW_INSECURE_REMOTE=0

# ─── Ollama / Kiro server (acp-server-ollama.js) ────────────────────────────

# Kiro CLI path (Linux/WSL binary)
# KIRO_CMD=/home/kartik/.local/bin/kiro-cli
# KIRO_ARGS=acp

# Bearer token(s) for Ollama server auth. Leave unset for localhost-only dev.
# AUTH_TOKEN=sk-local-dev-key

# ─── Shared ──────────────────────────────────────────────────────────────────

# HTTP port (codex server defaults to 3456, ollama server to 11434)
# PORT=3456

# Pre-warmed ACP processes
# POOL_SIZE=4

# Stateful session TTL (ms) — 30 min default
# SESSION_TTL_MS=1800000

# Prompt timeout (ms) — 10 min default; non-streaming returns 504 on expiry
# MAX_EXEC_MS=600000

# Auto-derive X-Session-Id from system-prompt hash (useful for LangFlow etc.)
# AUTO_SESSION_HASH=0

# Optional IP allowlist (comma-separated). Unset = allow all.
# ALLOWED_IPS=127.0.0.1,10.0.0.5

# Debug — verbose stderr + monolithic log file written to logs/
# DEBUG=1

# Override log directory (only used when DEBUG=1)
# LOG_DIR=./logs
