# Copy to .env and fill in your values.
# All variables are optional unless marked REQUIRED.

# ─── Interfaces (the file name = the REST surface it exposes) ──────────────────
#
#   acp-server-ollama.js   Ollama REST API   (default port 11434, default backend: kiro)
#   acp-server-openai.js   OpenAI REST API   (default port 3456,  default backend: codex)
#
# Either interface can drive either backend. The backend is chosen with a CLI flag:
#
#   node acp-server-ollama.js                  # Ollama  + kiro   (defaults)
#   node acp-server-openai.js                  # OpenAI  + codex  (defaults)
#   node acp-server-ollama.js --backend=codex  # Ollama  + codex  (mix & match)
#   node acp-server-openai.js --backend=kiro   # OpenAI  + kiro   (mix & match)
#
# (acp-server-codex.js still works as a deprecated alias for acp-server-openai.js.)

# ─── Backend: codex (codex-acp) ────────────────────────────────────────────────

# REQUIRED whenever the codex backend is selected (either interface) — passed to
# the codex-acp child process, never logged. NOT needed for the kiro backend.
OPENAI_API_KEY=sk-...

# Path to codex-acp binary (ships with @zed-industries/codex-acp)
# Linux/Mac:
# CODEX_CMD=./node_modules/.bin/codex-acp
# Windows (bash shebang in .bin/ won't work — use the native exe directly):
# CODEX_CMD=node_modules/@zed-industries/codex-acp-win32-x64/bin/codex-acp.exe

# Extra args for codex-acp. NOTE: split on spaces only — no shell-style quoting.
# CODEX_ARGS=

# Permission mode set after every session/new
# CODEX_MODE=full-access

# Default model when a request omits one
# CODEX_MODEL_DEFAULT=gpt-5.5

# Models to list at GET /v1/models (CSV)
# CODEX_AVAILABLE_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-mini

# ─── Backend: kiro (kiro-cli) ──────────────────────────────────────────────────

# Kiro CLI path (Linux/WSL binary)
# KIRO_CMD=/home/kartik/.local/bin/kiro-cli
# Extra args. NOTE: split on spaces only — no shell-style quoting.
# KIRO_ARGS=acp

# ─── Auth & remote-binding safety ──────────────────────────────────────────────
#
# The safety gate FOLLOWS THE BACKEND: when the codex (full-access) backend is
# selected and HOST is not localhost, the server refuses to start without auth
# tokens (or ALLOW_INSECURE_REMOTE=1). The kiro backend does not trigger the gate.
# Each interface uses its own token list: ACP_API_KEY (openai) / AUTH_TOKEN (ollama).

# Bearer token(s), comma-separated. Required for a remote codex backend.
# ACP_API_KEY=sk-local-dev-key      # acp-server-openai.js
# AUTH_TOKEN=sk-local-dev-key       # acp-server-ollama.js

# Bind address — openai defaults to 127.0.0.1, ollama defaults to 0.0.0.0
# HOST=127.0.0.1

# Override the remote-binding guard — only set if you really mean it
# ALLOW_INSECURE_REMOTE=0

# Optional IP allowlist (comma-separated). Unset = allow all.
# ALLOWED_IPS=127.0.0.1,10.0.0.5

# ─── Shared ────────────────────────────────────────────────────────────────────

# HTTP port (openai defaults to 3456, ollama to 11434)
# PORT=3456

# Working directory for spawned ACP processes (falls back to KIRO_CWD/CODEX_CWD/cwd)
# ACP_CWD=.

# Pre-warmed ACP processes
# POOL_SIZE=4

# Stateful session TTL (ms) — 30 min default
# SESSION_TTL_MS=1800000

# Prompt timeout (ms) — 10 min default; non-streaming returns 504 on expiry (openai only)
# MAX_EXEC_MS=600000

# Auto-derive X-Session-Id from system-prompt hash (useful for LangFlow etc.)
# AUTO_SESSION_HASH=0

# Debug — verbose stderr + monolithic log file written to logs/ (openai server)
# DEBUG=1

# Override log directory (only used when DEBUG=1)
# LOG_DIR=./logs
