# Copy to .env and edit as needed.
# All variables are optional — the server works with no .env.

# Bearer token for API auth. Comma-separate for multiple tokens.
# Leave unset to run open (fine for localhost-only dev).
# ACP_API_KEY=sk-local-dev-key

# Server port
PORT=3456

# Kiro CLI
KIRO_CMD=/home/kartik/.local/bin/kiro-cli   # WSL default install location
KIRO_ARGS=acp
# KIRO_CWD=/home/yourname                  # defaults to cwd at launch

# Optional IP allowlist (comma-separated). Unset = allow all.
# ALLOWED_IPS=127.0.0.1,10.0.0.5

# Timeouts (ms)
PING_INTERVAL=60000      # keepalive ping cadence
MAX_EXEC_MS=600000       # 10 min — auto-fail stuck jobs
JOB_TTL_MS=3600000       # 1 hr — retain completed jobs

# Debug — set to 1 for verbose JSON-RPC logging to stderr
# DEBUG=1
